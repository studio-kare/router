# Deployment mode: development | staging | production | public
DEPLOYMENT=development

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API
OPENAI_API_KEY=sk-...

# OpenRouter API
OPENROUTER_API_KEY=sk-or-...

# Azure OpenAI (optional, for future Azure support)
AZURE_OPENAI_API_KEY=placeholder_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_ENDPOINT=https://placeholder.openai.azure.com/

# Val.town deployment (for production)
VAL_TOWN_ENDPOINT=https://username-farmername.web.val.run

# Public deployment settings (only used when DEPLOYMENT=public)
PUBLIC_API_KEY=sk_public_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_DAILY_POOL=10000000
PUBLIC_ADMIN_TOKEN=admin_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
